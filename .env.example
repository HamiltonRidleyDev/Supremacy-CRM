# Copy this file to .env and fill in your values
# On the server: place this .env file next to docker-compose.yml

# Required — Claude AI for Mat Planner + Content Studio
ANTHROPIC_API_KEY=sk-ant-...

# Required — Session signing secret (use a long random string)
JWT_SECRET=change-me-to-a-random-string

# Zivvy (RainMaker) — data sync
ZIVVY_EMAIL=
ZIVVY_PASSWORD=
ZIVVY_SCHOOL_ID=

# Market Muscles — data sync
MM_TYPESENSE_API_KEY=
MM_CRM_TOKEN=
